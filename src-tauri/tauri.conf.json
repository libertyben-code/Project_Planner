{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "WMS Project Planner",
  "version": "1.1.0",
  "identifier": "com.wmsplanner.app",
  "build": {
    "frontendDist": "../renderer",
    "devUrl": "http://localhost:8080/home.html",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "WMS Project Planner",
        "url": "home.html",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
